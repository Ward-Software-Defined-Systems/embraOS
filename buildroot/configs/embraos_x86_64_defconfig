# embraOS x86_64 Buildroot defconfig
# Base: QEMU x86_64

BR2_x86_64=y
BR2_TOOLCHAIN_BUILDROOT_MUSL=y

# Kernel — use Buildroot's default config
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_USE_DEFCONFIG=y
BR2_LINUX_KERNEL_DEFCONFIG="x86_64"

# SquashFS support in kernel
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_EMBRAOS_PATH)/board/embraos/linux.fragment"

# Filesystem — we build our own images
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_TARGET_ROOTFS_SQUASHFS4_XZ=y

# No default init — embrad is PID 1
BR2_INIT_NONE=y

# No default /etc skeleton
BR2_ROOTFS_SKELETON_DEFAULT=y

# Rootfs overlay (resolv.conf, mount points, workspace dir)
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_EMBRAOS_PATH)/board/embraos/rootfs_overlay"

# Post-build and post-image scripts
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_EMBRAOS_PATH)/board/embraos/post_build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_EMBRAOS_PATH)/board/embraos/post_image.sh"

# Image tools
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_PACKAGE_HOST_MTOOLS=y

# OpenSSL + libcurl with TLS (required for git-remote-https)
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_CA_CERTIFICATES=y
BR2_PACKAGE_LIBCURL=y
BR2_PACKAGE_LIBCURL_OPENSSL=y
BR2_PACKAGE_LIBCURL_CURL=y

# Git (15+ tools depend on this)
BR2_PACKAGE_GIT=y

# OpenSSH client only — NO server (security invariant)
BR2_PACKAGE_OPENSSH=y
BR2_PACKAGE_OPENSSH_CLIENT=y

# embraOS packages
BR2_PACKAGE_EMBRAD=y
BR2_PACKAGE_EMBRA_APID=y
BR2_PACKAGE_EMBRA_TRUSTD=y
BR2_PACKAGE_EMBRA_BRAIN=y
BR2_PACKAGE_EMBRA_CONSOLE=y
BR2_PACKAGE_WARDSONDB=y
# embra-desktop installs via the rootfs overlay in build-image.sh Step 4.5
# (cross-compiled against Buildroot staging because iced 0.14 pulls
# softbuffer / wayland-client / xkbcommon via FFI). Buildroot package
# recipes exist (see buildroot/package/embra-desktop/) but the install
# path is the overlay, not the Buildroot package infra.

# Cage — single-fullscreen-client Wayland kiosk compositor (wlroots-based,
# C). Replaces our smithay-built embra-comp in the boot path. embrad
# spawns `cage -- /usr/bin/embra-desktop` so cage handles DRM/KMS scanout,
# libinput, and seat management — all the parts smithay's tty-udev
# pipeline would otherwise need to be hand-written. embra-comp's --winit
# backend (in `crates/embra-comp/`) is retained for nested host-side dev
# but isn't shipped in the rootfs.
BR2_PACKAGE_CAGE=y

# === embra-desktop graphics stack (experimental) ===
# Single-fullscreen-client kiosk: cage compositor + iced tiny_skia
# client. Software rendering only — no virgl, no GPU passthrough.
# Mesa3D + llvmpipe ship in the rootfs for any transitive GL touch even
# though iced's tiny_skia path bypasses Mesa entirely.

# LLVM (required by Mesa3D's llvmpipe Gallium driver)
BR2_PACKAGE_LLVM=y

# Mesa3D with llvmpipe software rasterizer
BR2_PACKAGE_MESA3D=y
BR2_PACKAGE_MESA3D_GALLIUM_DRIVER_LLVMPIPE=y
BR2_PACKAGE_MESA3D_OPENGL_EGL=y
BR2_PACKAGE_MESA3D_OPENGL_ES=y

# Wayland protocol + KMS userspace
BR2_PACKAGE_WAYLAND=y
BR2_PACKAGE_WAYLAND_PROTOCOLS=y
BR2_PACKAGE_LIBDRM=y

# Input handling
BR2_PACKAGE_LIBINPUT=y
BR2_PACKAGE_LIBEVDEV=y
BR2_PACKAGE_LIBXKBCOMMON=y
BR2_PACKAGE_XKEYBOARD_CONFIG=y

# Session manager (graceful handover of /dev/dri/card0 + /dev/input/*)
BR2_PACKAGE_SEATD=y

# Font stack
BR2_PACKAGE_FONTCONFIG=y
BR2_PACKAGE_FREETYPE=y
BR2_PACKAGE_HARFBUZZ=y
BR2_PACKAGE_DEJAVU=y

# Pixel format helpers
BR2_PACKAGE_PIXMAN=y
