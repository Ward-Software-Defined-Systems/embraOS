# embraOS aarch64 Buildroot defconfig
# Base: QEMU virt (ARM64) — Apple Silicon native via HVF

BR2_aarch64=y
BR2_TOOLCHAIN_BUILDROOT_MUSL=y

# Kernel — ARM64 arch default config (covers virtio, ext4, squashfs, PL011 UART)
# NOTE: Cannot use BR2_LINUX_KERNEL_USE_DEFCONFIG here because Buildroot appends
# "_defconfig" to the value, producing the invalid "defconfig_defconfig".
# USE_ARCH_DEFAULT_CONFIG uses the architecture's default directly.
BR2_LINUX_KERNEL=y
BR2_LINUX_KERNEL_USE_ARCH_DEFAULT_CONFIG=y

# SquashFS support in kernel
BR2_LINUX_KERNEL_CONFIG_FRAGMENT_FILES="$(BR2_EXTERNAL_EMBRAOS_PATH)/board/embraos/linux.fragment"

# Filesystem — we build our own images
BR2_TARGET_ROOTFS_SQUASHFS=y
BR2_TARGET_ROOTFS_SQUASHFS4_XZ=y

# No default init — embrad is PID 1
BR2_INIT_NONE=y

# No default /etc skeleton
BR2_ROOTFS_SKELETON_DEFAULT=y

# Rootfs overlay (resolv.conf, mount points, workspace dir)
BR2_ROOTFS_OVERLAY="$(BR2_EXTERNAL_EMBRAOS_PATH)/board/embraos/rootfs_overlay"

# Post-build and post-image scripts
BR2_ROOTFS_POST_BUILD_SCRIPT="$(BR2_EXTERNAL_EMBRAOS_PATH)/board/embraos/post_build.sh"
BR2_ROOTFS_POST_IMAGE_SCRIPT="$(BR2_EXTERNAL_EMBRAOS_PATH)/board/embraos/post_image.sh"

# Image tools
BR2_PACKAGE_HOST_GENIMAGE=y
BR2_PACKAGE_HOST_MTOOLS=y

# OpenSSL + libcurl with TLS (required for git-remote-https)
BR2_PACKAGE_OPENSSL=y
BR2_PACKAGE_CA_CERTIFICATES=y
BR2_PACKAGE_LIBCURL=y
BR2_PACKAGE_LIBCURL_OPENSSL=y
BR2_PACKAGE_LIBCURL_CURL=y

# Git (15+ tools depend on this)
BR2_PACKAGE_GIT=y

# OpenSSH client only — NO server (security invariant)
BR2_PACKAGE_OPENSSH=y
BR2_PACKAGE_OPENSSH_CLIENT=y

# embraOS packages
BR2_PACKAGE_EMBRAD=y
BR2_PACKAGE_EMBRA_APID=y
BR2_PACKAGE_EMBRA_TRUSTD=y
BR2_PACKAGE_EMBRA_BRAIN=y
BR2_PACKAGE_EMBRA_CONSOLE=y
BR2_PACKAGE_WARDSONDB=y
